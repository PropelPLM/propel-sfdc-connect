{
  "name": "@propelsoftwaresolutions/propel-sfdc-connect",
  "version": "2.0.0-SNAPSHOT.1",
  "description": "Wrapper module for jforce-propel",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./sfdx-lib": {
      "import": "./dist/sfdx-lib.js",
      "require": "./dist/sfdx-lib.cjs"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.js\"",
    "prepare": "npm run build"
  },
  "dependencies": {
    "amqplib": "^0.10.5",
    "csv-parser": "^3.0.0",
    "jsforce": "^3.6.3",
    "node-salesforce-jwt": "^1.1.0",
    "uuid": "^8.3.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "rollup": "^3.23.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PropelPLM/propel-sfdc-connect.git"
  },
  "keywords": [
    "express",
    "node"
  ],
  "author": "Propel Software Solutions",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PropelPLM/propel-sfdc-connect/issues"
  },
  "homepage": "https://github.com/PropelPLM/propel-sfdc-connect#readme"
}
